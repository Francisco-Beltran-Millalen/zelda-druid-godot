# ============================================================
# PROJECT ARTIFACTS
# Generated by the workflow stages — project-specific, not
# part of the workflow template.
# ============================================================

# Large binary assets (image gallery, concept art)
docs/assets/GDD/

# Generated PDFs
*.pdf

# Godot build cache and output
graybox-prototype/.godot/
graybox-prototype/target/

# Imported artifacts (raw imports + adapted files)
imported-artifacts/*
!imported-artifacts/.gitkeep

# ============================================================
# SESSION LOGS
# Conversation transcripts are project-specific and too large
# to include in the template. The workflow-changelog.md
# captures all meaningful changes in human-readable form.
# ============================================================

docs/logs/stage-*.txt
docs/logs/session-*.txt

# ============================================================
# RUNTIME & LOCAL
# ============================================================

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Local Claude Code settings (machine-specific)
.claude/settings.local.json

# ============================================================
# ARCHIVED / DEPRECATED
# ============================================================

legacy/
workflow/stages/legacy/
